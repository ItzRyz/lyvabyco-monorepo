// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. DYNAMIC SYSTEM MASTER TABLES (NO-ENUM)
// ==========================================

model Type {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "PRODUCT_STATUS", "ORDER_STATUS", "PAYMENT_STATUS", "PAYMENT_METHOD"
  nameId      String? // Lokalisasi Indonesia
  nameEn      String? // Lokalisasi Inggris
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  statuses       Status[]
  paymentMethods PaymentMethod[]

  @@map("types")
}

model Status {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "DRAFT", "PUBLISHED", "PENDING", "PAID", "DELIVERED", "EXPIRED"
  typeId      String
  type        Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)
  nameId      String // e.g., "Dibayar", "Kedaluwarsa"
  nameEn      String // e.g., "Paid", "Expired"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relasi balik ke entitas utama
  products        Product[]
  orderStatuses   Order[]     @relation("OrderStatus")
  paymentStatuses Order[]     @relation("PaymentStatus")
  statusLogs      StatusLog[]

  @@map("statuses")
}

model PaymentMethod {
  id            String   @id @default(uuid())
  code          String   @unique // e.g., "VA_BCA", "QRIS", "SHOPEEPAY"
  typeId        String
  type          Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)
  name          String // e.g., "BCA Virtual Account"
  xenditChannel String // Kode integrasi direct API Xendit (e.g., "BCA", "QRIS")
  isActive      Boolean  @default(true)
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@map("payment_methods")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique // e.g., "SUPER_ADMIN", "ADMIN", "CUSTOMER"
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Menu {
  id      String  @id @default(uuid())
  titleId String // Nama menu Bahasa Indonesia (e.g., "Manajemen Stok")
  titleEn String // Nama menu Bahasa Inggris (e.g., "Stock Management")
  path    String  @unique // Rute URL Next.js (e.g., "/admin/inventory")
  icon    String? // Nama key ikon Lucide/Shadcn (e.g., "Boxes")
  order   Int     @default(0) // Urutan tampilan menu di sidebar

  // Self-relation untuk Sub-Menu (Parent-Child)
  parentId String?
  parent   Menu?   @relation("MenuHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Menu[]  @relation("MenuHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi penghubung ke hak akses peran
  rolePermissions RolePermission[]

  @@map("menus")
}

// Tabel pivot (Many-to-Many) untuk mengatur hak akses menu per Role
model RolePermission {
  id     String @id @default(uuid())
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)

  // Opsional: Izin aksi granular (Acl) jika diperlukan
  canCreate Boolean @default(true)
  canRead   Boolean @default(true)
  canUpdate Boolean @default(true)
  canDelete Boolean @default(false)

  @@unique([roleId, menuId])
  @@map("role_permissions")
}

// ==========================================
// 2. USER MANAGEMENT & BETTER-AUTH SCHEMAS
// ==========================================

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions   Session[]
  accounts   Account[]
  addresses  Address[]
  orders     Order[]
  statusLogs StatusLog[]
  reviews    ProductReview[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("accounts")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ==========================================
// 3. PRODUCT, CATEGORY & WAREHOUSE INVENTORY
// ==========================================

model Category {
  id       String  @id @default(uuid())
  slug     String  @unique
  nameId   String
  nameEn   String
  imageUrl String?

  // Self-relation untuk kategori berjenjang (Parent-Child)
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String   @db.Text
  basePrice   Decimal  @db.Decimal(12, 2)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  statusId    String
  status      Status   @relation(fields: [statusId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants ProductVariant[]
  reviews  ProductReview[]

  @@map("products")
}

model ProductVariant {
  id        String  @id @default(uuid())
  sku       String  @unique
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Atribut Varian Perlengkapan Bayi
  size     String? // e.g., "S", "M", "L", "NB"
  color    String? // e.g., "Soft Pink", "Mint"
  ageGroup String? // e.g., "0-3 Months", "6-12 Months"

  priceOverride Decimal? @db.Decimal(12, 2) // Menimpa harga dasar jika bernilai spesifik
  imageUrl      String?

  // Dimensi Logistik (Pengiriman Paket)
  weight Int @default(0) // Dalam satuan Gram
  length Int @default(0) // Dalam satuan CM
  width  Int @default(0) // Dalam satuan CM
  height Int @default(0) // Dalam satuan CM

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouseStocks WarehouseStock[]
  orderItems      OrderItem[]

  @@map("product_variants")
}

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique // e.g., "GDG_JAKARTA_01"
  name      String
  address   String   @db.Text
  city      String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouseStocks WarehouseStock[]

  @@map("warehouses")
}

model WarehouseStock {
  id               String         @id @default(uuid())
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  stock            Int            @default(0) // Lokasi stok fisik aman dari race condition operasional

  @@unique([warehouseId, productVariantId])
  @@map("warehouse_stocks")
}

// ==========================================
// 4. CORE E-COMMERCE TRANSACTION & LOGISTICS
// ==========================================

model Address {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String // e.g., "Rumah", "Kantor"
  isMain       Boolean  @default(false)
  receiverName String
  phoneNumber  String
  street       String   @db.Text
  city         String
  district     String
  postalCode   String
  latitude     Float?
  longitude    Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]

  @@map("addresses")
}

model PromoCoupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String // e.g., "PERCENTAGE", "FLAT_NOMINAL"
  discountValue Decimal  @db.Decimal(12, 2)
  minSpend      Decimal  @default(0) @db.Decimal(12, 2)
  maxDiscount   Decimal? @db.Decimal(12, 2)
  expiresAt     DateTime
  quota         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@map("promo_coupons")
}

model Order {
  id                String        @id @default(uuid())
  orderNumber       String        @unique // e.g., "LYV-20260627-XXXXX"
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  shippingAddressId String
  shippingAddress   Address       @relation(fields: [shippingAddressId], references: [id])
  paymentMethodId   String
  paymentMethod     PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  promoCouponId     String?
  promoCoupon       PromoCoupon?  @relation(fields: [promoCouponId], references: [id])

  // Relasi master tabel untuk status transaksi
  orderStatusId   String
  orderStatus     Status @relation("OrderStatus", fields: [orderStatusId], references: [id])
  paymentStatusId String
  paymentStatus   Status @relation("PaymentStatus", fields: [paymentStatusId], references: [id])

  // Summary Keuangan & Ongkir
  totalItemsPrice Decimal @db.Decimal(12, 2)
  shippingCost    Decimal @db.Decimal(12, 2)
  discountAmount  Decimal @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal @db.Decimal(12, 2)

  // Spesifikasi Xendit Direct Integration
  xenditExternalId String    @unique // Reference ID yang dikirim ke Xendit
  xenditPaymentId  String? // ID transaksi resmi dari callback callback_virtual_accounts / qr_codes
  paymentQrString  String? // Data string raw untuk generator QRIS lokal
  paymentVaNumber  String? // Nomor Virtual Account mentah untuk dirender di apps/web
  paymentExpiredAt DateTime?

  // Informasi Kurir
  courierProvider String? // e.g., "JNE", "Sicepat"
  courierService  String? // e.g., "REG", "YES"
  trackingNumber  String? // Nomor Resi

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      OrderItem[]
  statusLogs StatusLog[]

  @@map("orders")
}

model OrderItem {
  id               String         @id @default(uuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  quantity         Int

  // Mengunci harga saat checkout untuk histori laporan keuangan yang valid
  priceAtPurchase Decimal @db.Decimal(12, 2)

  @@map("order_items")
}

// ==========================================
// 5. AUDIT LOGS, TIMELINE & REVIEWS
// ==========================================

model StatusLog {
  id       String @id @default(uuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  statusId String
  status   Status @relation(fields: [statusId], references: [id])

  // Aktor pengubah status (Sistem, Admin, atau Pembeli)
  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])

  reason    String?  @db.Text // Penjelasan jika pembatalan/perubahan dilakukan manual
  createdAt DateTime @default(now())

  @@map("status_logs")
}

model ProductReview {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // Batasan integer 1-5 diurus pada level Express / Zod
  comment   String?  @db.Text
  mediaUrl  String? // Untuk foto/video unboxing dari konsumen
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_reviews")
}
